# Copy this file to `.env` and fill in your local values.
# Do not commit secrets.

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Better Auth
BETTER_AUTH_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pitch-perfect"

# Email (SMTP)
EMAIL_FROM=""
SMTP_USER=""
SMTP_PASS=""
SMTP_HOST=""
SMTP_PORT=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cron / admin
CRON_SECRET=""
SUPER_ADMIN_PASSWORD=""

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Paytm
PAYTM_MODE="test"
PAYTM_MID=""
PAYTM_MERCHANT_KEY=""
PAYTM_WEBSITE=""
PAYTM_CALLBACK_URL="https://example.com/api/book/callback"
PAYTM_HOSTNAME=""

# Test Paytm
TEST_PAYTM_MID=""
TEST_PAYTM_MERCHANT_KEY=""
TEST_PAYTM_WEBSITE=""
TEST_PAYTM_CALLBACK_URL="https://example.com/api/book/callback"
TEST_PAYTM_HOSTNAME=""
